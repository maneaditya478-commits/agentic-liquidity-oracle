# =============================================================================
# Banking Oracle — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/banking_oracle

# JWT Settings
JWT_SECRET_KEY=your-super-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin seed credentials (used on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456
ADMIN_EMAIL=admin@treasury.local

# EVM Blockchain (use a local Hardhat/Anvil node for dev)
ORACLE_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
EVM_RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ICP Canister
ICP_CANISTER_ID=rrkah-fqaaa-aaaaa-aaaaq-cai
ICP_HOST=https://ic0.app
ICP_STUB_MODE=true

# Agent / Simulation tuning
AGENT_POLL_INTERVAL_SECONDS=30
VAR_THRESHOLD_USD=500000.0
RISK_PROBABILITY_THRESHOLD=0.60
RECOVERY_THRESHOLD=0.30
MAX_SIMULATIONS=10000
SIMULATION_HORIZON_HOURS=48

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
