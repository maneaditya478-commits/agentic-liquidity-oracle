# ─────────────────────────────────────────────────────────────────────
# Agentic AI Financial Risk & Liquidity Balancing Oracle
# Environment Variables — copy to .env and fill in values
# ─────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://oracle:oracle_secret@postgres:5432/treasury_oracle

# ── JWT Authentication ────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin Seed Credentials ────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@Oracle2026
ADMIN_EMAIL=admin@oracle.local

# ── Blockchain / EVM ─────────────────────────────────────────────────
# Hardhat test key (account #0) — NEVER use on mainnet
ORACLE_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
EVM_RPC_URL=http://hardhat:8545
CONTRACT_ADDRESS=

# ── ICP / Motoko ─────────────────────────────────────────────────────
ICP_CANISTER_ID=
ICP_HOST=https://ic0.app
ICP_STUB_MODE=true

# ── AI Agent Configuration ────────────────────────────────────────────
AGENT_POLL_INTERVAL_SECONDS=30
VAR_THRESHOLD_USD=500000
RISK_PROBABILITY_THRESHOLD=0.80
RECOVERY_THRESHOLD=0.45
MAX_SIMULATIONS=10000
SIMULATION_HORIZON_HOURS=48

# ── CORS ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
