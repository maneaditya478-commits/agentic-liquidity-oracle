# ─────────────────────────────────────────────────────────────────────
# Ethereum Sepolia Testnet Deployment Configuration
# ─────────────────────────────────────────────────────────────────────

# Alchemy or Infura HTTP RPC URL for the Sepolia Testnet
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Wallet Private Key used to deploy the contract (must have test ETH)
# WARNING: NEVER commit your actual private key to GitHub!
DEPLOYER_PRIVATE_KEY=your_deployer_wallet_private_key_here

# Wallet Address assigned the ORACLE_ROLE (the agent backend address)
ORACLE_ADDRESS=your_oracle_agent_wallet_address_here
